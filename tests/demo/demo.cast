{"version": 2, "width": 100, "height": 28, "timestamp": 1747526400, "title": "frappe_fixture_normalize demo"}
[0.0, "o", "\u001b[2J\u001b[H"]
[0.3, "o", "\u001b[1;38;2;255;255;255;48;2;220;38;38m  \u2716  PROBLEM  \u001b[0m\r\n"]
[0.9, "o", "\u001b[1;33mstock `bench export-fixtures` rewrites fixture files wholesale.\u001b[0m\r\n"]
[1.9, "o", "\u001b[90mper-machine `creation` ordering + leaking `modified` timestamps =>\r\nevery export looks like a 252-KB diff, even when zero records changed.\u001b[0m\r\n"]
[3.6, "o", "\r\n"]
[3.8, "o", "$ \u001b[1mbench --site myapp.localhost export-fixtures --app myapp\u001b[0m\r\n"]
[4.4, "o", "Exporting Property Setter app myapp filters [['module', 'in', ['MyApp']]]\r\n"]
[4.9, "o", "Exporting Custom Field   app myapp filters [['module', 'in', ['MyApp']]]\r\n"]
[6.0, "o", "\r\n"]
[6.1, "o", "$ \u001b[1mgit diff --stat fixtures/\u001b[0m\r\n"]
[6.5, "o", " fixtures/custom_field.json     | 10889 +++++++++++++++++++++--------------\r\n"]
[6.8, "o", " fixtures/property_setter.json  |  1618 ++++++++++--------------------------\r\n"]
[7.0, "o", " 2 files changed, 6253 insertions(+), 6254 deletions(-)\r\n"]
[8.6, "o", "\r\n"]
[8.7, "o", "\u001b[31mwholesale rewrite. two devs editing Issue + Subscription = guaranteed conflict.\u001b[0m\r\n"]
[11.0, "o", "\u001b[2J\u001b[H"]
[11.2, "o", "\u001b[1;38;2;255;255;255;48;2;22;163;74m  \u2714  SOLUTION  \u001b[0m\r\n"]
[11.8, "o", "\u001b[1;32minstall frappe_fixture_normalize. stock command auto-overridden.\u001b[0m\r\n"]
[13.2, "o", "\r\n"]
[13.4, "o", "$ \u001b[1mbench get-app https://github.com/ananyo141/frappe-fixture-normalize.git\u001b[0m\r\n"]
[14.0, "o", "Getting frappe_fixture_normalize\r\nInstalling frappe_fixture_normalize\r\n"]
[15.2, "o", "$ \u001b[1mbench --site myapp.localhost install-app frappe_fixture_normalize\u001b[0m\r\n"]
[16.0, "o", "Installing frappe_fixture_normalize...\r\n"]
[17.0, "o", "\r\n"]
[17.2, "o", "$ \u001b[1mbench --site myapp.localhost export-fixtures --app myapp\u001b[0m\r\n"]
[17.8, "o", "Exporting Property Setter app myapp filters [['module', 'in', ['MyApp']]]\r\n"]
[18.2, "o", "Exporting Custom Field   app myapp filters [['module', 'in', ['MyApp']]]\r\n"]
[18.5, "o", "normalized fixtures for myapp at /workspace/frappe-bench/apps/myapp/myapp/fixtures\r\n"]
[19.8, "o", "\r\n"]
[19.9, "o", "$ \u001b[1mls fixtures/\u001b[0m\r\n"]
[20.2, "o", "\u001b[1;34mcustom_field\u001b[0m    \u001b[1;34mproperty_setter\u001b[0m\r\n"]
[21.0, "o", "$ \u001b[1mls fixtures/custom_field/\u001b[0m\r\n"]
[21.3, "o", "issue.json   subscription.json   user.json   ...   \u001b[90m# one file per target doctype\u001b[0m\r\n"]
[22.6, "o", "\r\n"]
[22.7, "o", "\u001b[1;32msecond run, same DB, expect zero diff.\u001b[0m\r\n"]
[24.0, "o", "$ \u001b[1mbench --site myapp.localhost export-fixtures --app myapp\u001b[0m > /dev/null\r\n"]
[25.2, "o", "$ \u001b[1mgit diff --stat fixtures/\u001b[0m\r\n"]
[25.6, "o", "(clean)\r\n"]
[26.8, "o", "\r\n"]
[26.9, "o", "\u001b[1;32mdeterminism. merge-safe per-target splits. override-on-install.\u001b[0m\r\n"]
[28.4, "o", "\r\n"]
